  "keyFeatures": [
    "Employee check-in/check-out tracking",
    "Automatic late arrival detection",
    "Flexible and base schedule types",
    "PDF and Excel report generation",
    "Weekly tardiness email notifications",
    "Admin dashboard with filtering",
    "Employee management (CRUD operations)",
    "Configurable time limits and settings"
  ],
  "publicApiSurface": [
    "GET /empleado/{id}/buscar - Search employee and mark attendance",
    "POST /asistencia/{id}/salida - Confirm check-out",
    "GET /admin/asistencias - View attendance dashboard",
    "GET /admin/asistencias/reporte/pdf - Generate PDF report",
    "GET /admin/asistencias/reporte/excel - Generate Excel report",
    "GET /admin/empleados - List all employees",
    "POST /admin/empleados - Create new employee",
    "PUT /admin/empleados/{id} - Update employee",
    "DELETE /admin/empleados/{id} - Delete employee",
    "GET /admin/usuarios - Manage users",
    "POST /admin/preferencias/configuracion - Update system settings",
    "php artisan app:enviar-reporte-retardos-semanales - Send weekly tardiness report"
  ]
